# API credentials for AgentAuditor's LLM-calling pipeline stages
# (preprocess, demo, demo_repair, infer, infer_fix2, direct_eval).
# Copy this file to .env and fill in real values. .env is gitignored - never commit real keys.

AGENTAUDITOR_API_KEY=sk-REPLACE_ME
AGENTAUDITOR_API_BASE=https://api.openai.com/v1

# Optional per-stage model overrides (defaults shown are the paper's original choices).
# Set these if your endpoint only serves specific models.
AGENTAUDITOR_MODEL_PREPROCESS=gpt-oss-20b
AGENTAUDITOR_MODEL_DEMO=gpt-oss-20b
AGENTAUDITOR_MODEL_DEMO_REPAIR=gpt-oss-20b
AGENTAUDITOR_MODEL_INFER=gpt-oss-20b
AGENTAUDITOR_MODEL_INFER_FIX2=gpt-oss-20b
AGENTAUDITOR_MODEL_DIRECT_EVAL=gpt-oss-20b

# Optional: override preprocess's top_p (some OpenAI-compatible servers reject top_p=0,
# which was this stage's original default - see AgentAuditor/tasks/preprocess.py).
# AGENTAUDITOR_TOP_P_PREPROCESS=1
